<div id="chat-launcher" class="chat-launcher shadow-lg">
    <i class="bi bi-robot"></i>
</div>

<div id="chat-window" class="chat-window shadow-lg">
    <div class="chat-header d-flex justify-content-between align-items-center bg-dark text-white px-3 py-2">
        <span class="fw-bold"><i class="bi bi-robot me-2 text-warning"></i>AI Companion</span>
        <button type="button" class="btn-close btn-close-white" id="chat-close"></button>
    </div>
    <div class="chat-messages p-3" id="chat-messages">
        <div class="message bot mb-2">Xin chào! Em là trợ lý ảo của Luxury Hotel. Em có thể giúp gì cho anh/chị?</div>
    </div>
    <div class="chat-input-area border-top p-2 d-flex gap-2 bg-white">
        <input type="text" id="chat-input" class="form-control form-control-sm rounded-pill px-3" placeholder="Hỏi AI..." />
        <button class="btn btn-warning btn-sm rounded-circle d-flex align-items-center justify-content-center" id="chat-send" style="width: 32px; height: 32px;">
            <i class="bi bi-send-fill fs-6"></i>
        </button>
    </div>
</div>

<style>
    .chat-launcher {
        position: fixed;
        bottom: 30px;
        right: 30px;
        width: 60px;
        height: 60px;
        background-color: #ffc107;
        color: #212529;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        cursor: pointer;
        z-index: 2000;
        transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .chat-launcher:hover { transform: scale(1.15); color: #000; }

    .chat-window {
        position: fixed;
        bottom: 100px;
        right: 30px;
        width: 350px;
        height: 500px;
        background: #fff;
        border-radius: 12px;
        display: none;
        flex-direction: column;
        z-index: 2001;
        overflow: hidden;
        border: 1px solid rgba(0,0,0,0.1);
    }

    .chat-messages {
        flex: 1;
        overflow-y: auto;
        background: #fdfcf7;
        display: flex;
        flex-direction: column;
        scrollbar-width: thin;
    }

    .message {
        padding: 10px 14px;
        border-radius: 18px;
        font-size: 0.92rem;
        max-width: 85%;
        line-height: 1.4;
        animation: chat-fadeIn 0.3s ease-out;
        word-wrap: break-word;
        overflow-wrap: break-word;
        white-space: pre-wrap; /* Quan trọng: Giữ lại xuống dòng từ AI */
        width: fit-content;
    }
    .message.bot {
         align-self: flex-start;
    display: inline-block;  /* tự tính width theo toàn bộ content */
    width: auto;            /* không fix cứng */
    max-width: 88%;   
    }
    .message.user {
        align-self: flex-end;
        background: #ffc107;
        color: #000;
        border-bottom-right-radius: 4px;
    }
    .message.bot:has(.typing-indicator) {
        display: flex;
        align-items: center;
    }

    .typing-indicator {
        display: flex;
        gap: 4px;
        padding: 4px 8px;
    }

    .typing-indicator span {
        width: 8px;
        height: 8px;
        background-color: #999;
        border-radius: 50%;
        display: inline-block;
        animation: chat-bounce 1.4s infinite ease-in-out;
    }

    .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
    .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }

    @@keyframes chat-bounce {
        0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
        30% { transform: translateY(-6px); opacity: 1; }
    }

    @@keyframes chat-fadeIn {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const launcher = document.getElementById('chat-launcher');
        const chatWin = document.getElementById('chat-window');
        const closeBtn = document.getElementById('chat-close');
        const input = document.getElementById('chat-input');
        const sendBtn = document.getElementById('chat-send');
        const msgList = document.getElementById('chat-messages');

        if (!launcher) return;

        // --- CẤU HÌNH SIGNALR ---
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .withAutomaticReconnect()
            .build();

        connection.start().catch(err => console.error(err.toString()));

        launcher.onclick = () => {
            chatWin.style.display = chatWin.style.display === 'flex' ? 'none' : 'flex';
            if (chatWin.style.display === 'flex') input.focus();
        };

        if (closeBtn) closeBtn.onclick = () => chatWin.style.display = 'none';

        function addMsg(txt, type) {
            const div = document.createElement('div');
            div.className = `message ${type} mb-3 shadow-sm`;
            div.innerText = txt;
            msgList.appendChild(div);
            msgList.scrollTop = msgList.scrollHeight;
            return div;
        }

        let currentLoadingMsg = null;

        connection.on("ReceiveChunk", (chunk) => {
            if (currentLoadingMsg) {
                // Nếu đang hiển thị typing indicator, chuyển sang text
                const indicator = currentLoadingMsg.querySelector('.typing-indicator');
                if (indicator) {
                    currentLoadingMsg.innerText = '';
                }
                currentLoadingMsg.innerText += chunk;
                msgList.scrollTop = msgList.scrollHeight;
            }
        });

        connection.on("Finished", () => {
            currentLoadingMsg = null;
        });

        async function doSend() {
            const msg = input.value.trim();
            if (!msg) return;

            addMsg(msg, 'user');
            input.value = '';

            const loading = addMsg('', 'bot');
            loading.innerHTML = `
                <div class="typing-indicator">
                    <span></span>
                    <span></span>
                    <span></span>
                </div>
            `;
            currentLoadingMsg = loading;

            try {
                await connection.invoke("SendMessage", msg);
            } catch (err) {
                loading.innerText = "Lỗi kết nối SignalR: " + err.toString();
                currentLoadingMsg = null;
            }
        }

        if (sendBtn) sendBtn.onclick = doSend;
        if (input) input.onkeypress = (e) => { if (e.key === 'Enter') doSend(); };
    });
</script>
