@page
@model HotelManagementSystem.Web.Pages.PaymentCallbackModel
@{
    ViewData["Title"] = "Kết quả thanh toán";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow rounded-4 text-center">
                <div class="card-body p-5">
                    @if (Model.IsSuccess)
                    {
                        <div class="rounded-circle bg-success bg-opacity-10 d-flex align-items-center justify-content-center mx-auto mb-4"
                             style="width:100px;height:100px">
                            <i class="bi bi-check-circle-fill text-success" style="font-size:3rem"></i>
                        </div>
                        <h3 class="fw-bold text-success mb-3">Thanh toán thành công!</h3>
                        <p class="text-muted mb-4">@Model.ResultMessage</p>

                        @if (!string.IsNullOrEmpty(Model.OrderId))
                        {
                            <div class="bg-light rounded-3 p-3 mb-4">
                                <div class="text-muted small text-uppercase" style="font-size:.65rem;letter-spacing:.07em">Mã đơn hàng</div>
                                <div class="fw-bold">@Model.OrderId</div>
                            </div>
                        }

                        <div class="d-flex gap-2 justify-content-center">
                            <a asp-page="/MyReservations" class="btn btn-primary rounded-3 px-4">
                                <i class="bi bi-list-check me-1"></i>Xem đặt phòng
                            </a>
                            <a asp-page="/Rooms" class="btn btn-outline-secondary rounded-3 px-4">
                                <i class="bi bi-house me-1"></i>Trang chủ
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="rounded-circle bg-danger bg-opacity-10 d-flex align-items-center justify-content-center mx-auto mb-4"
                             style="width:100px;height:100px">
                            <i class="bi bi-x-circle-fill text-danger" style="font-size:3rem"></i>
                        </div>
                        <h3 class="fw-bold text-danger mb-3">Thanh toán thất bại</h3>
                        <p class="text-muted mb-4">@Model.ResultMessage</p>

                        <div class="d-flex gap-2 justify-content-center">
                            <a asp-page="/Rooms" class="btn btn-primary rounded-3 px-4">
                                <i class="bi bi-arrow-counterclockwise me-1"></i>Thử lại
                            </a>
                            <a asp-page="/Index" class="btn btn-outline-secondary rounded-3 px-4">
                                <i class="bi bi-house me-1"></i>Trang chủ
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
