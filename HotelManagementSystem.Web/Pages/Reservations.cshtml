@page
@model HotelManagementSystem.Web.Pages.ReservationsModel
@{
    ViewData["Title"] = "Quản lý lưu trú";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-person-badge"></i> Quản lý Check-in / Check-out</h2>
        <a asp-page="/Index" class="btn btn-outline-primary"><i class="bi bi-grid-3x3-gap"></i> Sơ đồ phòng</a>
    </div>

    @* Hiển thị thông báo *@
    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Số Phòng</th>
                        <th>Khách Hàng</th>
                        <th>Ngày Đến</th>
                        <th>Ngày Đi (Dự kiến)</th>
                        <th>Trạng Thái</th>
                        <th class="text-end pe-4">Thao tác nghiệp vụ</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Reservations.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">Không có khách nào cần xử lý hiện tại.</td>
                        </tr>
                    }
                    @foreach (var res in Model.Reservations)
                    {
                        <tr data-reservation-id="@res.Id">
                            <td class="ps-4">
                                <span class="fw-bold text-primary">@res.Room.RoomNumber</span><br />
                                <small class="text-muted">@res.Room.RoomType</small>
                            </td>
                            <td>
                                <div>@res.Customer.FullName</div>
                                <small class="text-muted"><i class="bi bi-phone"></i> @res.Customer.Phone</small>
                            </td>
                            <td>@res.CheckInDate.ToString("dd/MM/yyyy")</td>
                            <td>@res.CheckOutDate.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (res.Status == "Confirmed")
                                {
                                    <span class="badge bg-warning text-dark"><i class="bi bi-clock"></i> Chờ Check-in</span>
                                }
                                else if (res.Status == "CheckedIn")
                                {
                                    <span class="badge bg-success"><i class="bi bi-door-open"></i> Đang ở</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <a asp-page="/Reservations/Services" asp-route-reservationId="@res.Id" class="btn btn-outline-info btn-sm px-3 shadow-sm">
                                    <i class="bi bi-bag-plus"></i> Dịch vụ
                                </a>

                                @if (res.Status == "Confirmed")
                                {
                                    @* Form gọi OnPostCheckInAsync *@
                                    <form method="post" asp-page-handler="CheckIn" asp-route-id="@res.Id" class="d-inline">
                                        <button type="submit" class="btn btn-primary btn-sm px-3 shadow-sm">
                                            <i class="bi bi-box-arrow-in-right"></i> Check-in
                                        </button>
                                    </form>
                                }
                                else if (res.Status == "CheckedIn")
                                {
                                    @* Form gọi OnPostCheckOutAsync *@
                                    <form method="post" asp-page-handler="CheckOut" asp-route-id="@res.Id" class="d-inline">
                                        <button type="submit" class="btn btn-danger btn-sm px-3 shadow-sm"
                                                onclick="return confirm('Bạn có chắc muốn thanh toán và trả phòng?')">
                                            <i class="bi bi-cash-stack"></i> Check-out
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .table thead th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
    }

    .badge {
        padding: 0.5em 0.8em;
    }

    .btn-sm {
        border-radius: 20px;
    }
</style>

@section Scripts {
<script src="~/js/signalr/dist/browser/signalr.js"></script>
<script>
"use strict";
(function () {
    const reservationConnection = new signalR.HubConnectionBuilder()
        .withUrl("/reservationHub")
        .withAutomaticReconnect()
        .build();

    reservationConnection.on("ReservationCreated", function (data) {
        console.log("New reservation created:", data);
        
        // Find the table body
        const tbody = document.querySelector("table tbody");
        if (tbody) {
            // Create new row for the reservation
            const newRow = document.createElement("tr");
            newRow.setAttribute("data-reservation-id", data.reservationId);
            newRow.className = "table-success";
            
            const checkInDate = new Date(data.checkInDate).toLocaleDateString('vi-VN');
            const checkOutDate = new Date(data.checkOutDate).toLocaleDateString('vi-VN');
            
            newRow.innerHTML = `
                <td class="ps-4">
                    <span class="fw-bold text-primary">${data.roomNumber}</span><br />
                    <small class="text-muted">Unknown Type</small>
                </td>
                <td>
                    <div>${data.customerName}</div>
                    <small class="text-muted"><i class="bi bi-phone"></i> —</small>
                </td>
                <td>${checkInDate}</td>
                <td>${checkOutDate}</td>
                <td>
                    <span class="badge bg-warning text-dark"><i class="bi bi-clock"></i> Chờ Check-in</span>
                </td>
                <td class="text-end pe-4">
                    <a href="#" class="btn btn-outline-info btn-sm px-3 shadow-sm" onclick="return false;">
                        <i class="bi bi-bag-plus"></i> Dịch vụ
                    </a>
                    <form method="post" asp-page-handler="CheckIn" asp-route-id="${data.reservationId}" class="d-inline">
                        <button type="submit" class="btn btn-primary btn-sm px-3 shadow-sm">
                            <i class="bi bi-box-arrow-in-right"></i> Check-in
                        </button>
                    </form>
                </td>
            `;
            
            tbody.insertBefore(newRow, tbody.firstChild);
            
            // Highlight briefly
            setTimeout(() => newRow.classList.remove("table-success"), 2000);
        }
    });

    reservationConnection.on("ReservationCheckedIn", function (data) {
        console.log("Check-in received:", data);
        // Find and update the corresponding row
        const row = document.querySelector(`tr[data-reservation-id="${data.reservationId}"]`);
        if (row) {
            // Update status badge
            const statusCell = row.querySelector("td:nth-child(5)");
            if (statusCell) {
                statusCell.innerHTML = '<span class="badge bg-success"><i class="bi bi-door-open"></i> Đang ở</span>';
            }
            // Update action buttons
            const actionCell = row.querySelector("td:nth-child(6)");
            if (actionCell) {
                actionCell.innerHTML = `<form method="post" asp-page-handler="CheckOut" asp-route-id="${data.reservationId}" class="d-inline" onsubmit="return confirm('Bạn có chắc muốn thanh toán và trả phòng?')">
                    <button type="submit" class="btn btn-danger btn-sm px-3 shadow-sm">
                        <i class="bi bi-cash-stack"></i> Check-out
                    </button>
                </form>`;
            }
            // Highlight the row briefly
            row.classList.add("table-success");
            setTimeout(() => row.classList.remove("table-success"), 2000);
        }
    });

    reservationConnection.on("ReservationCheckedOut", function (data) {
        console.log("Check-out received:", data);
        // Remove or fade out the row since reservation is completed
        const row = document.querySelector(`tr[data-reservation-id="${data.reservationId}"]`);
        if (row) {
            row.classList.add("table-danger");
            setTimeout(() => {
                row.style.opacity = "0.5";
            }, 1000);
        }
    });

    reservationConnection.start()
        .then(function () {
            console.log("SignalR ReservationHub connected");
        })
        .catch(function (err) {
            return console.error(err.toString());
        });

    window.addEventListener("beforeunload", () => {
        reservationConnection.stop();
    });
})();
</script>
}