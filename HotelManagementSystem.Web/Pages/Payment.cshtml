@page
@model HotelManagementSystem.Web.Pages.PaymentModel
@{
    ViewData["Title"] = "Thanh toán";
}

<style>
    .ls-wide { letter-spacing: .07em; }
    .payment-header {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    }
    .qr-glow {
        background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ee 100%);
    }
    .price-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: .55rem 0;
    }
    .total-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: .75rem 0;
        margin-top: .25rem;
        border-top: 2px solid #dee2e6;
    }
</style>

<div class="container py-4">

    <!-- Header -->
    <div class="mb-4">
        <h4 class="fw-bold mb-1">
            <i class="bi bi-credit-card-2-front me-2 text-primary"></i>Thanh toán đặt phòng
        </h4>
        <p class="text-muted small mb-0">Kiểm tra thông tin và quét mã VietQR để thanh toán.</p>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm rounded-3 mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <div asp-validation-summary="ModelOnly" class="d-inline"></div>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4 align-items-start">

        <!-- ── Left: Booking recap ── -->
        <div class="col-lg-7">

            <!-- Customer -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4 d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center" style="width:42px;height:42px;min-width:42px">
                        <i class="bi bi-person-fill text-primary fs-5"></i>
                    </div>
                    <div>
                        <div class="text-muted ls-wide" style="font-size:.65rem;text-transform:uppercase">Khách hàng</div>
                        <div class="fw-bold">@Model.CustomerName</div>
                    </div>
                </div>
            </div>

            <!-- Room -->
            <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">
                <div class="bg-primary p-4">
                    <div class="text-white">
                        <div class="text-white-50 small" style="font-size:.65rem;text-transform:uppercase;letter-spacing:.07em">
                            <i class="bi bi-door-open me-1"></i>Phòng đã chọn
                        </div>
                        <div class="fw-bold fs-4 lh-1 mt-1">@Model.SelectedRoom!.RoomNumber</div>
                        <div class="text-white-50 small mt-1">@Model.SelectedRoom.RoomType — @Model.SelectedRoom.Capacity người</div>
                    </div>
                </div>
            </div>

            <!-- Dates -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <p class="fw-bold text-uppercase text-muted ls-wide mb-3" style="font-size:.7rem">
                        <i class="bi bi-calendar3 me-1"></i> Chi tiết lưu trú
                    </p>
                    <div class="row g-3">
                        <div class="col-sm-4">
                            <div class="bg-light rounded-3 p-3 text-center">
                                <i class="bi bi-calendar2-check text-success d-block fs-4 mb-1"></i>
                                <div class="text-muted" style="font-size:.65rem;text-transform:uppercase">Nhận phòng</div>
                                <div class="fw-bold small">@Model.RequestData.CheckInDate.ToString("dd/MM/yyyy")</div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="bg-light rounded-3 p-3 text-center">
                                <i class="bi bi-calendar2-x text-danger d-block fs-4 mb-1"></i>
                                <div class="text-muted" style="font-size:.65rem;text-transform:uppercase">Trả phòng</div>
                                <div class="fw-bold small">@Model.RequestData.CheckOutDate.ToString("dd/MM/yyyy")</div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="bg-light rounded-3 p-3 text-center">
                                <i class="bi bi-moon-stars text-warning d-block fs-4 mb-1"></i>
                                <div class="text-muted" style="font-size:.65rem;text-transform:uppercase">Số đêm</div>
                                <div class="fw-bold small">@Model.Nights đêm</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Price breakdown -->
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <p class="fw-bold text-uppercase text-muted ls-wide mb-3" style="font-size:.7rem">
                        <i class="bi bi-calculator me-1"></i> Chi tiết thanh toán
                    </p>

                    <div class="price-row">
                        <span class="text-muted small">
                            <i class="bi bi-house-door me-1"></i>Phòng @Model.SelectedRoom.RoomNumber × @Model.Nights đêm
                        </span>
                        <span class="fw-semibold small">@Model.RoomTotal.ToString("N0") ₫</span>
                    </div>

                    @if (Model.SelectedServices.Any())
                    {
                        <div class="text-muted ls-wide mt-2 mb-1" style="font-size:.6rem;text-transform:uppercase">Dịch vụ bổ sung</div>
                        @foreach (var svc in Model.SelectedServices)
                        {
                            <div class="price-row">
                                <span class="text-muted small">
                                    <i class="bi bi-check-circle text-success me-1"></i>@svc.Name
                                </span>
                                <span class="fw-semibold small">@svc.Price.ToString("N0") ₫</span>
                            </div>
                        }
                    }

                    <div class="total-row">
                        <span class="fw-bold">Tổng giá trị đặt phòng</span>
                        <span class="fw-bold text-secondary fs-5">@Model.TotalPrice.ToString("N0") ₫</span>
                    </div>

                    <div class="mt-3 p-3 rounded-3" style="background:#fff8e1;border:1px solid #ffe082">
                        <div class="price-row">
                            <span class="fw-semibold small">
                                <i class="bi bi-lock-fill text-warning me-1"></i>Thanh toán ngay (1 đêm đặt cọ)
                            </span>
                            <span class="fw-bold text-warning-emphasis">@Model.DepositAmount.ToString("N0") ₫</span>
                        </div>
                        <div class="price-row mb-0">
                            <span class="text-muted small">
                                <i class="bi bi-clock me-1"></i>Thanh toán khi trả phòng
                            </span>
                            <span class="text-muted small">@((Model.TotalPrice - Model.DepositAmount).ToString("N0")) ₫</span>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- ── Right: Payment options ── -->
        <div class="col-lg-5">
            <div class="card border-0 shadow rounded-4 sticky-top" style="top:1.25rem">

                <!-- Payment method tabs -->
                <div class="card-header bg-white rounded-top-4 border-0 p-4 pb-0">
                    <ul class="nav nav-tabs" id="paymentTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="vietqr-tab" data-bs-toggle="tab"
                                    data-bs-target="#vietqr-pane" type="button" role="tab">
                                <i class="bi bi-qr-code me-1"></i>VietQR
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="momo-tab" data-bs-toggle="tab"
                                    data-bs-target="#momo-pane" type="button" role="tab">
                                <i class="bi bi-wallet2 me-1"></i>MoMo
                            </button>
                        </li>
                    </ul>
                </div>

                <div class="tab-content">

                    <!-- VietQR tab -->
                    <div class="tab-pane fade show active" id="vietqr-pane" role="tabpanel">
                        <div class="payment-header text-white border-0 p-4">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-qr-code fs-5"></i>
                                <span class="fw-bold">Quét mã để thanh toán</span>
                            </div>
                            <p class="text-white-50 small mb-0 mt-1">Sử dụng ứng dụng ngân hàng để quét mã VietQR bên dưới.</p>
                        </div>

                        <div class="card-body p-4 text-center">
                            <div class="qr-glow rounded-4 p-4 mb-3 d-inline-block">
                                <img src="@Model.VietQrUrl"
                                     alt="VietQR Payment Code"
                                     class="img-fluid rounded-3"
                                     style="max-width:260px" />
                            </div>

                            <div class="bg-warning-subtle border border-warning-subtle rounded-3 p-3 mb-3 text-start">
                                <div class="d-flex gap-2 align-items-start">
                                    <i class="bi bi-info-circle-fill text-warning mt-1"></i>
                                    <div class="small">
                                        <div class="fw-bold mb-1">Hướng dẫn thanh toán</div>
                                        <ol class="mb-0 ps-3 lh-lg">
                                            <li>Mở ứng dụng ngân hàng</li>
                                            <li>Chọn <strong>Quét QR</strong></li>
                                            <li>Quét mã QR ở trên</li>
                                            <li>Xác nhận chuyển khoản</li>
                                            <li>Nhấn <strong>Hoàn tất</strong> bên dưới</li>
                                        </ol>
                                    </div>
                                </div>
                            </div>

                            <div class="bg-light rounded-3 p-3 mb-3">
                                <div class="text-muted ls-wide" style="font-size:.6rem;text-transform:uppercase">Số tiền đặt cọ (1 đêm)</div>
                                <div class="fw-bold text-primary fs-4">@Model.DepositAmount.ToString("N0") ₫</div>
                            </div>
                        </div>

                        <div class="card-footer bg-white border-0 p-4 pt-0">
                            <form method="post">
                                <input type="hidden" asp-for="RequestData.CustomerId" />
                                <input type="hidden" asp-for="RequestData.RoomId" />
                                <input type="hidden" asp-for="RequestData.CheckInDate" />
                                <input type="hidden" asp-for="RequestData.CheckOutDate" />
                                @foreach (var id in Model.RequestData.SelectedServiceIds)
                                {
                                    <input type="hidden" name="RequestData.SelectedServiceIds" value="@id" />
                                }
                                <button type="submit" class="btn btn-success w-100 py-2 fw-bold rounded-3 mb-2">
                                    <i class="bi bi-check-circle me-2"></i>Đã thanh toán — Hoàn tất đặt phòng
                                </button>
                            </form>
                            <a asp-page="/Booking" asp-route-roomId="@Model.RequestData.RoomId"
                               class="btn btn-outline-secondary w-100 rounded-3 btn-sm">
                                <i class="bi bi-arrow-left me-1"></i>Quay lại
                            </a>
                        </div>
                    </div>

                    <!-- MoMo tab -->
                    <div class="tab-pane fade" id="momo-pane" role="tabpanel">
                        <div class="text-white border-0 p-4" style="background: linear-gradient(135deg, #a50064 0%, #d82d8b 100%);">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-wallet2 fs-5"></i>
                                <span class="fw-bold">Thanh toán qua MoMo</span>
                            </div>
                            <p class="text-white-50 small mb-0 mt-1">Bạn sẽ được chuyển sang MoMo để hoàn tất thanh toán.</p>
                        </div>

                        <div class="card-body p-4 text-center">
                            <div class="mb-4">
                                <div class="rounded-circle bg-danger bg-opacity-10 d-flex align-items-center justify-content-center mx-auto mb-3"
                                     style="width:80px;height:80px">
                                    <i class="bi bi-wallet2 text-danger" style="font-size:2rem"></i>
                                </div>
                                <h5 class="fw-bold">Ví MoMo</h5>
                                <p class="text-muted small">Thanh toán nhanh chóng và an toàn qua ví điện tử MoMo</p>
                            </div>

                            <div class="bg-light rounded-3 p-3 mb-3">
                                <div class="text-muted ls-wide" style="font-size:.6rem;text-transform:uppercase">Số tiền đặt cọ (1 đêm)</div>
                                <div class="fw-bold text-danger fs-4">@Model.DepositAmount.ToString("N0") ₫</div>
                            </div>

                            <div class="bg-info-subtle border border-info-subtle rounded-3 p-3 mb-3 text-start">
                                <div class="d-flex gap-2 align-items-start">
                                    <i class="bi bi-shield-check text-info mt-1"></i>
                                    <div class="small">
                                        <div class="fw-bold mb-1">Thanh toán an toàn</div>
                                        <ul class="mb-0 ps-3 lh-lg">
                                            <li>Nhấn nút bên dưới để chuyển sang MoMo</li>
                                            <li>Xác nhận thanh toán trên ứng dụng MoMo</li>
                                            <li>Bạn sẽ được chuyển về trang kết quả</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card-footer bg-white border-0 p-4 pt-0">
                            <form method="post" asp-page-handler="MoMo">
                                <input type="hidden" asp-for="RequestData.CustomerId" />
                                <input type="hidden" asp-for="RequestData.RoomId" />
                                <input type="hidden" asp-for="RequestData.CheckInDate" />
                                <input type="hidden" asp-for="RequestData.CheckOutDate" />
                                @foreach (var id in Model.RequestData.SelectedServiceIds)
                                {
                                    <input type="hidden" name="RequestData.SelectedServiceIds" value="@id" />
                                }
                                <button type="submit" class="btn w-100 py-2 fw-bold rounded-3 mb-2 text-white"
                                        style="background: linear-gradient(135deg, #a50064 0%, #d82d8b 100%);">
                                    <i class="bi bi-wallet2 me-2"></i>Thanh toán qua MoMo
                                </button>
                            </form>
                            <a asp-page="/Booking" asp-route-roomId="@Model.RequestData.RoomId"
                               class="btn btn-outline-secondary w-100 rounded-3 btn-sm">
                                <i class="bi bi-arrow-left me-1"></i>Quay lại
                            </a>
                        </div>
                    </div>

                </div>

            </div>
        </div>

    </div>
</div>
