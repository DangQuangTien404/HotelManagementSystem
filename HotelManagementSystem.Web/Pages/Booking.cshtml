@page
@model HotelManagementSystem.Web.Pages.BookingModel
@{
    ViewData["Title"] = "Đặt phòng";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
<style>
    .ls-wide { letter-spacing: .07em; }
    .service-card input:checked + .service-label .svc-badge {
        background-color: rgba(255,255,255,.25) !important;
        color: #fff !important;
        border-color: transparent !important;
    }
    .summary-header {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    }
    .summary-icon {
        width: 36px; height: 36px; min-width: 36px;
    }
    .form-control:focus, .form-select:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 .2rem rgba(13,110,253,.1);
    }
    .flatpickr-day.reserved {
        background: #fee2e2 !important;
        color: #dc2626 !important;
        text-decoration: line-through;
    }
    .flatpickr-day.reserved:hover {
        background: #fecaca !important;
    }
</style>

<div class="container py-4">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-3 mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Page header -->
    <div class="mb-4">
        <h4 class="fw-bold mb-1">
            <i class="bi bi-calendar2-plus me-2 text-primary"></i>Đặt phòng mới
        </h4>
        <p class="text-muted small mb-0">Chọn phòng, ngày lưu trú và các dịch vụ bạn muốn.</p>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm rounded-3 mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <div asp-validation-summary="ModelOnly" class="d-inline"></div>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form method="post">
        <input type="hidden" asp-for="RequestData.CustomerId" />
        <input type="hidden" asp-for="RequestData.RoomId" />

        <div class="row g-4 align-items-start">

            <!-- ── Left column ── -->
            <div class="col-lg-7">

                <!-- Room info card (read-only) -->
                <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">
                    <div class="card-body p-0">
                        <div class="bg-primary p-4 d-flex justify-content-between align-items-start">
                            <div class="text-white">
                                <div class="text-white-50 small mb-1" style="font-size:.65rem;text-transform:uppercase;letter-spacing:.07em">
                                    <i class="bi bi-door-open me-1"></i>Phòng đã chọn
                                </div>
                                <div class="fw-bold fs-4 lh-1">@Model.SelectedRoom!.RoomNumber</div>
                                <div class="text-white-50 small mt-1">@Model.SelectedRoom.RoomType</div>
                            </div>
                            <a asp-page="/Rooms" class="btn btn-light btn-sm rounded-pill fw-semibold">
                                <i class="bi bi-arrow-left me-1"></i>Đổi phòng
                            </a>
                        </div>
                        <div class="d-flex border-top">
                            <div class="flex-fill text-center py-3 border-end">
                                <i class="bi bi-people-fill text-primary d-block mb-1"></i>
                                <div class="fw-semibold small">@Model.SelectedRoom.Capacity người</div>
                                <div class="text-muted" style="font-size:.65rem">Sức chứa</div>
                            </div>
                            <div class="flex-fill text-center py-3">
                                <i class="bi bi-moon-stars-fill text-warning d-block mb-1"></i>
                                <div class="fw-bold text-primary small">@Model.SelectedRoom.BasePrice.ToString("N0") ₫</div>
                                <div class="text-muted" style="font-size:.65rem">Mỗi đêm</div>
                            </div>
                        </div>
                    </div>
                </div>

                        <!-- Dates card -->
                        <div class="card border-0 shadow-sm rounded-4 mb-4">
                            <div class="card-body p-4">
                                <p class="fw-bold text-uppercase text-muted ls-wide mb-3" style="font-size:.7rem">
                                    <i class="bi bi-calendar3 me-1"></i> Ngày lưu trú
                                </p>
                                <div class="row g-3">
                                    <div class="col-sm-6">
                                        <label class="form-label fw-semibold small">Ngày nhận phòng</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-end-0 rounded-start-3">
                                                <i class="bi bi-calendar-event text-muted"></i>
                                            </span>
                                            <input asp-for="RequestData.CheckInDate"
                                                   id="checkInInput"
                                                   type="text"
                                                   autocomplete="off"
                                                   readonly
                                                   class="form-control border-start-0 rounded-end-3" />
                                        </div>
                                    </div>
                                    <div class="col-sm-6">
                                        <label class="form-label fw-semibold small">Ngày trả phòng</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-end-0 rounded-start-3">
                                                <i class="bi bi-calendar-x text-muted"></i>
                                            </span>
                                            <input asp-for="RequestData.CheckOutDate"
                                                   id="checkOutInput"
                                                   type="text"
                                                   autocomplete="off"
                                                   readonly
                                                   class="form-control border-start-0 rounded-end-3" />
                                        </div>
                                    </div>
                                </div>
                                <!-- Reserved-date legend -->
                                <div id="reservedLegend" class="mt-3 d-none">
                                    <div class="d-flex align-items-center gap-2 flex-wrap">
                                        <span class="badge rounded-pill bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25" style="font-size:.7rem">
                                            <i class="bi bi-circle-fill me-1" style="font-size:.4rem;vertical-align:middle"></i>Ngày đã có đặt phòng (không thể chọn)
                                        </span>
                                    </div>
                                    <div id="reservedList" class="d-flex flex-wrap gap-1 mt-2"></div>
                                </div>
                            </div>
                        </div>
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-4">
                        <p class="fw-bold text-uppercase text-muted ls-wide mb-1" style="font-size:.7rem">
                            <i class="bi bi-stars me-1"></i> Dịch vụ đi kèm
                        </p>
                        <p class="text-muted small mb-3">Tùy chọn — Chọn một hoặc nhiều dịch vụ bổ sung.</p>

                        @if (!Model.AvailableServices.Any())
                        {
                            <div class="text-center py-5 text-muted">
                                <i class="bi bi-inbox fs-1 d-block mb-2 opacity-50"></i>
                                <span class="small">Hiện chưa có dịch vụ đang hoạt động.</span>
                            </div>
                        }
                        else
                        {
                            <div class="row g-2">
                                @foreach (var service in Model.AvailableServices)
                                {
                                    <div class="col-sm-6 service-card">
                                        <input class="btn-check"
                                               type="checkbox"
                                               name="RequestData.SelectedServiceIds"
                                               value="@service.Id"
                                               id="svc_@service.Id"
                                               autocomplete="off"
                                               @(Model.RequestData.SelectedServiceIds.Contains(service.Id) ? "checked" : null) />
                                        <label class="btn btn-outline-primary w-100 text-start rounded-3 p-3 service-label" for="svc_@service.Id">
                                            <div class="d-flex justify-content-between align-items-center gap-2">
                                                <span class="fw-semibold small">@service.Name</span>
                                                <span class="badge bg-primary-subtle text-primary border border-primary-subtle svc-badge" style="white-space:nowrap">
                                                    @service.Price.ToString("N0") ₫
                                                </span>
                                            </div>
                                        </label>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

            </div>

            <!-- ── Right column: sticky summary ── -->
            <div class="col-lg-5">
                <div class="card border-0 shadow rounded-4 sticky-top" style="top:1.25rem">

                    <div class="card-header summary-header text-white rounded-top-4 border-0 p-4">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-receipt fs-5"></i>
                            <span class="fw-bold">Tóm tắt đặt phòng</span>
                        </div>
                    </div>

                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush">

                            <li class="list-group-item px-4 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="summary-icon rounded-circle bg-light d-flex align-items-center justify-content-center">
                                        <i class="bi bi-person-fill text-primary"></i>
                                    </div>
                                    <div>
                                        <div class="text-muted ls-wide" style="font-size:.65rem;text-transform:uppercase">Khách hàng</div>
                                        <div class="fw-semibold small">@(string.IsNullOrEmpty(Model.CustomerName) ? "—" : Model.CustomerName)</div>
                                    </div>
                                </div>
                            </li>

                            <li class="list-group-item px-4 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="summary-icon rounded-circle bg-light d-flex align-items-center justify-content-center">
                                        <i class="bi bi-door-open-fill text-primary"></i>
                                    </div>
                                    <div>
                                        <div class="text-muted ls-wide" style="font-size:.65rem;text-transform:uppercase">Phòng số</div>
                                        <div class="fw-semibold small">
                                            @(Model.SelectedRoom != null
                                                ? $"{Model.SelectedRoom.RoomNumber} — {Model.SelectedRoom.RoomType}"
                                                : "—")
                                        </div>
                                    </div>
                                </div>
                            </li>

                            <li class="list-group-item px-4 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="summary-icon rounded-circle bg-light d-flex align-items-center justify-content-center">
                                        <i class="bi bi-calendar2-check-fill text-success"></i>
                                    </div>
                                    <div>
                                        <div class="text-muted ls-wide" style="font-size:.65rem;text-transform:uppercase">Nhận phòng</div>
                                        <div class="fw-semibold small" id="summaryCheckIn">—</div>
                                    </div>
                                </div>
                            </li>

                            <li class="list-group-item px-4 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="summary-icon rounded-circle bg-light d-flex align-items-center justify-content-center">
                                        <i class="bi bi-calendar2-x-fill text-danger"></i>
                                    </div>
                                    <div>
                                        <div class="text-muted ls-wide" style="font-size:.65rem;text-transform:uppercase">Trả phòng</div>
                                        <div class="fw-semibold small" id="summaryCheckOut">—</div>
                                    </div>
                                </div>
                            </li>

                            <li class="list-group-item px-4 py-3 bg-light rounded-bottom-4">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="summary-icon rounded-circle bg-white shadow-sm d-flex align-items-center justify-content-center">
                                        <i class="bi bi-moon-stars-fill text-warning"></i>
                                    </div>
                                    <div>
                                        <div class="text-muted ls-wide" style="font-size:.65rem;text-transform:uppercase">Số đêm lưu trú</div>
                                        <div class="fw-bold" id="summaryNights">—</div>
                                    </div>
                                </div>
                            </li>

                        </ul>
                    </div>

                    <div class="card-footer bg-white border-0 p-4 rounded-bottom-4">
                        <button type="submit" class="btn btn-dark w-100 py-2 fw-bold rounded-3">
                            <i class="bi bi-check2-circle me-2"></i>Xác nhận đặt phòng
                        </button>
                    </div>

                </div>
            </div>

        </div>
    </form>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/vn.js"></script>
<script>
    const roomId = @Model.RequestData.RoomId;
    let reservedRanges = [];

    function dateInReserved(date) {
        return reservedRanges.some(r => date >= r.from && date < r.to);
    }

    function rangesOverlap(checkIn, checkOut) {
        return reservedRanges.some(r => checkIn < r.to && checkOut > r.from);
    }

    let fpIn, fpOut;

    function initPickers() {
        const disableFn = date => dateInReserved(date);
        const today = new Date(); today.setHours(0,0,0,0);

        fpIn = flatpickr('#checkInInput', {
            locale: 'vn',
            dateFormat: 'Y-m-d',
            minDate: 'today',
            disable: [disableFn],
            onDayCreate(_, __, ___, dayElem) {
                if (dateInReserved(dayElem.dateObj)) dayElem.classList.add('reserved');
            },
            onChange([selected]) {
                if (!selected) return;
                const next = new Date(selected); next.setDate(next.getDate() + 1);
                fpOut.set('minDate', next);
                if (fpOut.selectedDates[0] && fpOut.selectedDates[0] <= selected) fpOut.clear();
                updateSummary();
            }
        });

        fpOut = flatpickr('#checkOutInput', {
            locale: 'vn',
            dateFormat: 'Y-m-d',
            minDate: 'today',
            disable: [disableFn],
            onDayCreate(_, __, ___, dayElem) {
                if (dateInReserved(dayElem.dateObj)) dayElem.classList.add('reserved');
            },
            onChange([selected]) {
                updateSummary();
                validateOverlap();
            }
        });

        // Restore existing model values
        const ciVal = '@Model.RequestData.CheckInDate.ToString("yyyy-MM-dd")';
        const coVal = '@Model.RequestData.CheckOutDate.ToString("yyyy-MM-dd")';
        if (ciVal && ciVal !== '0001-01-01') fpIn.setDate(ciVal, false);
        if (coVal && coVal !== '0001-01-01') fpOut.setDate(coVal, false);
        updateSummary();
    }

    function fmtDate(val) {
        if (!val) return '—';
        const [y, m, d] = val.split('-');
        return `${d}/${m}/${y}`;
    }

    function updateSummary() {
        const ciVal = document.getElementById('checkInInput').value;
        const coVal = document.getElementById('checkOutInput').value;
        document.getElementById('summaryCheckIn').textContent  = fmtDate(ciVal);
        document.getElementById('summaryCheckOut').textContent = fmtDate(coVal);
        const nights = (ciVal && coVal)
            ? Math.max(0, Math.round((new Date(coVal) - new Date(ciVal)) / 86400000))
            : 0;
        document.getElementById('summaryNights').textContent = nights > 0 ? `${nights} đêm` : '—';
    }

    function validateOverlap() {
        const ciVal = document.getElementById('checkInInput').value;
        const coVal = document.getElementById('checkOutInput').value;
        if (!ciVal || !coVal) return;
        const ci = new Date(ciVal), co = new Date(coVal);
        if (rangesOverlap(ci, co)) {
            document.querySelector('button[type=submit]').disabled = true;
            document.querySelector('button[type=submit]').title = 'Khoảng thời gian đã bị trùng với đặt phòng khác';
            alert('Khoảng ngày bạn chọn trùng với một đặt phòng đã có. Vui lòng chọn ngày khác.');
            fpOut.clear();
            document.querySelector('button[type=submit]').disabled = false;
        }
    }

    function renderReservedList() {
        if (!reservedRanges.length) return;
        const legend = document.getElementById('reservedLegend');
        const list   = document.getElementById('reservedList');
        legend.classList.remove('d-none');
        reservedRanges.forEach(r => {
            const fromD = r.from.toLocaleDateString('vi-VN', { day:'2-digit', month:'2-digit' });
            const toD   = r.to.toLocaleDateString('vi-VN',   { day:'2-digit', month:'2-digit' });
            const span = document.createElement('span');
            span.className = 'badge rounded-pill text-bg-danger';
            span.style.fontSize = '.7rem';
            span.textContent = `${fromD} – ${toD}`;
            list.appendChild(span);
        });
    }

    async function loadReservedDates() {
        try {
            const resp = await fetch(`/Booking?handler=ReservedDates&roomId=${roomId}`);
            const data = await resp.json();
            reservedRanges = data.map(d => ({ from: new Date(d.from), to: new Date(d.to) }));
        } catch { reservedRanges = []; }
        initPickers();
        renderReservedList();
    }

    loadReservedDates();
</script>
}
